# Copy to .env.development.local for local API overrides (optional, gitignored if you add *.local)
#
# Azure dev API (default — committed in .env.development / .env.production):
# VITE_API_URL=https://tax-talent-dev-app.azurewebsites.net
#
# Local TTS API while debugging:
# VITE_API_URL=http://127.0.0.1:8000
#
# Web UI base path (default /static/ in vite.config). Capacitor: npm run build:capacitor
# VITE_APP_BASE=/static/
